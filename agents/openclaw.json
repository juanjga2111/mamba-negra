        "primary": "google/gemini-3.1-pro",
        "fallbacks": [
          "google/gemini-2.5-pro"
        ]
      },
      "contextTokens": 500000,
      "thinkingDefault": "low",
      "userTimezone": "America/Bogota",
      "compaction": {
        "memoryFlush": {
          "enabled": true
        },
        "reserveTokensFloor": 40000
      },
      "contextPruning": {
        "mode": "cache-ttl"
      },
      "bootstrapMaxChars": 25000,
      "maxConcurrent": 7,
      "subagents": {
        "maxSpawnDepth": 1,
        "maxChildrenPerAgent": 5,
        "maxConcurrent": 12
      }
