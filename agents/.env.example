# OpenClaw Environment Variables — Mamba Negra (Multi-Agent)
# Copy to ~/.openclaw/.env on the VM

# Gateway Authentication
# Generate a secure random token (e.g., `openssl rand -hex 32`)
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# ============================================================
# Telegram Bot Tokens (3 bots — one per agent)
# ============================================================
# Obtain from BotFather: https://t.me/BotFather
# Command: /newbot → follow prompts → copy token

# Estratega bot (@StrategyMambabot — created 12-Mar-2026)
TELEGRAM_BOT_TOKEN_ESTRATEGA=your-estratega-bot-token-here

# PM bot (@PMMambabot — created 16-Mar-2026)
TELEGRAM_BOT_TOKEN_PM=your-pm-bot-token-here

# Admin bot (@AdmonMambaBot — created 16-Mar-2026)
TELEGRAM_BOT_TOKEN_ADMIN=your-admin-bot-token-here

# ============================================================
# LLM API KEY
# ============================================================

# Google Gemini (default — works with free tier)
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# MCP Google Drive (configure in Fase 1B — pospuesto)
# ============================================================

# Root folder ID where client briefs and documents are stored
# Find it in the Drive URL: https://drive.google.com/drive/folders/<FOLDER_ID>
# GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here
